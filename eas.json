{
  "cli": {
    "version": ">= 16.1.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" }
    },

    "dev-testflight": {
      "developmentClient": true,
      "distribution": "store",
      "ios": {
        "simulator": false
      }
    },
    "preview-store": {
      "distribution": "store",
      "channel": "preview",
      "ios": {
        "simulator": false
      }
    },

    "production": {
      "android": {
        "image": "latest",
        "buildType": "app-bundle",
        "env": {
          "ANDROID_TARGET_SDK_VERSION": "35",
          "ANDROID_COMPILE_SDK_VERSION": "35"
        },
        "gradleCommand": ":app:bundleRelease"
      },
      "ios": {
        "simulator": false
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6743389519"
      }
    }
  }
}




