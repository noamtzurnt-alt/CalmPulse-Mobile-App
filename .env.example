# ─── Firebase ────────────────────────────────────────────────────────────────
# Found in your Firebase Console → Project Settings → Your apps
EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
EXPO_PUBLIC_FIREBASE_APP_ID=1:YOUR_SENDER_ID:ios:YOUR_APP_ID

# ─── RevenueCat ──────────────────────────────────────────────────────────────
# Found in RevenueCat Dashboard → Your App → API Keys
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=appl_YOUR_REVENUECAT_IOS_KEY_HERE
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=goog_YOUR_REVENUECAT_ANDROID_KEY_HERE

# ─── Facebook SDK ─────────────────────────────────────────────────────────────
# Found in Meta for Developers → Your App → Settings → Basic
FB_APP_ID=YOUR_FACEBOOK_APP_ID
FB_DISPLAY_NAME=YOUR_APP_DISPLAY_NAME
FB_CLIENT_TOKEN=YOUR_FACEBOOK_CLIENT_TOKEN

# ─── Google Sign-In ───────────────────────────────────────────────────────────
# Found in Google Cloud Console → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com

# ─── API URLs ─────────────────────────────────────────────────────────────────
EXPO_PUBLIC_PULSE_API_URL=https://your-pulse-proxy.vercel.app/api/pulse
EXPO_PUBLIC_MEDIA_API_URL=https://your-media-api.vercel.app/api/uploads
