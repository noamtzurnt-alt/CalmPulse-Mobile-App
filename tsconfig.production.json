{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strict": false,
    "noImplicitReturns": false,
    "noImplicitThis": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "app/**/*",
    "components/**/*",
    "lib/**/*",
    "hooks/**/*",
    "constants/**/*",
    "store/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".expo",
    "android",
    "ios",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/__tests__/**/*",
    "**/jest.config.js",
    "**/jest.setup.js",
    "**/metro.config.js",
    "**/babel.config.js",
    "**/eslint.config.js"
  ]
}

