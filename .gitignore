app-example

# ─── Environment / Secrets ───────────────────────────────────────────────────
# All .env files are excluded; only .env.example is allowed
.env
.env.*
!.env.example

# iOS Xcode local env (contains local node path)
ios/.xcode.env.local

# ─── Firebase Service Account Files ──────────────────────────────────────────
# These files contain real API keys and must never be committed
app/GoogleService-Info.plist
app/google-services.json
ios/CalmPulse/GoogleService-Info.plist

# ─── Pulse Proxy (separate Vercel project) ───────────────────────────────────
pulse-proxy/
